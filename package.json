{
	"name": "infinite-canvas-monorepo",
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"dev": "pnpm --filter playground dev",
		"test": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "pnpm -r exec rm -rf dist",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,md,yml,yaml}": "biome check --write --no-errors-on-unmatched"
	},
	"license": "MIT",
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=24"
	}
}
