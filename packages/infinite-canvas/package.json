{
	"name": "@jamesyong42/infinite-canvas",
	"version": "1.1.0",
	"description": "Infinite canvas library with ECS layout engine, React components, and WebGL rendering",
	"license": "MIT",
	"author": "James Yong",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jamesyong-42/infinite-canvas.git",
		"directory": "packages/infinite-canvas"
	},
	"bugs": {
		"url": "https://github.com/jamesyong-42/infinite-canvas/issues"
	},
	"homepage": "https://github.com/jamesyong-42/infinite-canvas#readme",
	"keywords": [
		"infinite-canvas",
		"canvas",
		"react",
		"ecs",
		"entity-component-system",
		"webgl",
		"layout-engine",
		"drag-and-drop",
		"zoom",
		"pan",
		"resize",
		"snap",
		"spatial",
		"whiteboard",
		"figma",
		"freeform",
		"widget",
		"three",
		"r3f",
		"react-three-fiber",
		"responsive",
		"undo-redo",
		"dark-mode"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./advanced": {
			"import": {
				"types": "./dist/advanced.d.mts",
				"default": "./dist/advanced.mjs"
			},
			"require": {
				"types": "./dist/advanced.d.cts",
				"default": "./dist/advanced.cjs"
			}
		},
		"./devtools": {
			"import": {
				"types": "./dist/devtools.d.mts",
				"default": "./dist/devtools.mjs"
			},
			"require": {
				"types": "./dist/devtools.d.cts",
				"default": "./dist/devtools.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"typesVersions": {
		"*": {
			"advanced": [
				"./dist/advanced.d.mts"
			],
			"devtools": [
				"./dist/devtools.d.mts"
			]
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "vitest run",
		"prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE",
		"postpack": "rm -f ./README.md ./LICENSE"
	},
	"dependencies": {
		"@jamesyong42/reactive-ecs": "^0.2.0"
	},
	"peerDependencies": {
		"@react-three/fiber": "^9.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"three": ">=0.170.0"
	},
	"peerDependenciesMeta": {
		"three": {
			"optional": true
		},
		"@react-three/fiber": {
			"optional": true
		}
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@react-three/fiber": "^9.5.0",
		"@types/rbush": "^4.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/three": "^0.183.1",
		"publint": "^0.3.18",
		"rbush": "^4.0.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"three": "^0.183.2",
		"tsdown": "^0.21.10",
		"vitest": "^4.1.4"
	},
	"files": [
		"dist"
	]
}
